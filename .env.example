# HELPDESK.AI Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# --- Server ---
PORT=5000
NODE_ENV=development
SECRET_KEY=your-secret-key-here

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/helpdesk
MONGODB_URI=mongodb://localhost:27017/helpdesk

# --- AI/ML Services ---
OPENAI_API_KEY=sk-...
HUGGINGFACE_API_TOKEN=hf_...
OCR_SERVICE_API_KEY=

# --- Email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Auth ---
JWT_SECRET=your-j...hars
JWT_EXPIRY=24h
PASSWORD_RESET_EXPIRY=***

# --- Redis ---
# Redis password for authentication (leave empty for no auth in dev)
REDIS_PASSWORD=

# --- CORS & Security Headers ---
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=https://helpdeskaiv1.vercel.app,http://localhost:5173,http://localhost:3000
# Optional: regex pattern for flexible origin matching (e.g., staging deployments)
# ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app
# Token for /metrics endpoint authentication
METRICS_TOKEN=
