# ─── Supabase Configuration (Backend) ───────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ─── Google Gemini AI (REQUIRED) ────────────────────────────────────────────
# The backend's AI analysis pipeline calls Gemini on every /ai/analyze_ticket
# request. Without this key the backend will crash on startup or return 500s.
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Supabase Anon Key (Frontend / Mobile) ──────────────────────────────────
# Required by @supabase/supabase-js in the Frontend and MobileApp.
# This is the public "anon" key (safe to expose in the browser).
# Without it the frontend throws: AuthApiError: Invalid API key
# Find it in your Supabase dashboard → Settings → API → Project API keys
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ─── Startup Mode ────────────────────────────────────────────────────────────
# Set ALLOW_DEGRADED_STARTUP=1 to allow backend startup even if
# duplicate/RAG models fail to load (useful in offline/dev environments).
ALLOW_DEGRADED_STARTUP=0

# ─── Sentence Transformers Model Path ────────────────────────────────────────
# Provide a local path to avoid downloading from HuggingFace on every start.
# Example: ./models/all-MiniLM-L6-v2
SENTENCE_TRANSFORMER_MODEL_PATH=

# ─── Readiness Check ─────────────────────────────────────────────────────────
# Set REQUIRE_SUPABASE=true to include Supabase in the strict readiness gate.
REQUIRE_SUPABASE=false
