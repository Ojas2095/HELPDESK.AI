{
  "info": {
    "name": "HELPDESK.AI API",
    "description": "AI-powered helpdesk ticket management system with automated triage, routing, and resolution.",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "contact": {
      "name": "HELPDESK.AI Team",
      "url": "https://github.com/ritesh-1918/HELPDESK.AI"
    }
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "description": "User authentication endpoints",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"securePassword123\",\n  \"name\": \"John Doe\",\n  \"role\": \"client\"\n}"
            },
            "description": "Register a new user account. Roles: client, freelancer, admin"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"securePassword123\"\n}"
            },
            "description": "Login and receive access token"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/refresh",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "description": "Refresh expired access token"
          }
        }
      ]
    },
    {
      "name": "Tickets",
      "description": "Support ticket management",
      "item": [
        {
          "name": "Create Ticket",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/tickets",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Login page not loading\",\n  \"description\": \"The login page shows a blank screen after the latest update.\",\n  \"priority\": \"high\",\n  \"category\": \"bug\"\n}"
            },
            "description": "Create a new support ticket. Triggers AI analysis pipeline."
          }
        },
        {
          "name": "List Tickets",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tickets?status=open&priority=high&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tickets"],
              "query": [
                { "key": "status", "value": "open" },
                { "key": "priority", "value": "high" },
                { "key": "limit", "value": "20" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "description": "List tickets with optional filters: status, priority, assigned_to, category"
          }
        },
        {
          "name": "Get Ticket",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/tickets/{{ticketId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "description": "Get ticket details including AI analysis results and timeline"
          }
        },
        {
          "name": "Update Ticket Status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/tickets/{{ticketId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\",\n  \"assigned_to\": \"agent-001\"\n}"
            },
            "description": "Update ticket status or assignment"
          }
        }
      ]
    },
    {
      "name": "AI Analysis",
      "description": "AI-powered ticket analysis endpoints",
      "item": [
        {
          "name": "Analyze Ticket",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/ai/analyze/{{ticketId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "description": "Trigger AI analysis for a ticket (category, priority, sentiment)"
          }
        },
        {
          "name": "Get Analysis Result",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/ai/analysis/{{ticketId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "description": "Retrieve AI analysis results for a ticket"
          }
        }
      ]
    },
    {
      "name": "Bank Sync",
      "description": "Bank account synchronization",
      "item": [
        {
          "name": "List Connectors",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/bank-sync/connectors",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "description": "List available bank connectors"
          }
        },
        {
          "name": "Import Transactions",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/bank-sync/import",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"mock\",\n  \"account_id\": \"mock-checking-001\"\n}"
            },
            "description": "Bulk import transactions from bank account"
          }
        }
      ]
    },
    {
      "name": "Search",
      "description": "Search functionality",
      "item": [
        {
          "name": "Search Tickets",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/search?q=login+issue&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "search"],
              "query": [
                { "key": "q", "value": "login issue" },
                { "key": "limit", "value": "10" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "description": "Full-text search across tickets. Query max 200 chars."
          }
        }
      ]
    },
    {
      "name": "Health",
      "description": "System health checks",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health",
            "description": "Basic health check endpoint"
          }
        }
      ]
    }
  ]
}
